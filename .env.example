# =============================================================================
# AI PROVIDER SELECTION
# =============================================================================
# Choose: "gemini" or "bedrock"
AI_PROVIDER=gemini

# =============================================================================
# GEMINI AI CONFIGURATION (when AI_PROVIDER=gemini)
# =============================================================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# AWS BEDROCK CONFIGURATION (when AI_PROVIDER=bedrock)
# =============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
# Model ID — examples:
#   anthropic.claude-3-5-sonnet-20241022-v2:0
#   anthropic.claude-3-haiku-20240307-v1:0
#   us.anthropic.claude-sonnet-4-20250514-v1:0
#   amazon.titan-text-express-v1
#   meta.llama3-70b-instruct-v1:0
#   mistral.mistral-large-2402-v1:0
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# =============================================================================
# SMTP EMAIL CONFIGURATION
# =============================================================================
# SMTP server settings for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Sender name that appears in "From" field
FROM_NAME=Your Name

# Path to your resume PDF (will be attached to emails)
# Replace with your actual resume filename
RESUME_PATH=./Your_Resume.pdf

# =============================================================================
# EMAIL TEST MODE (Optional)
# =============================================================================
# Set to 'true' to redirect all emails to a test inbox (useful for testing)
EMAIL_TEST_MODE=false
EMAIL_TEST_INBOX=test@yopmail.com
