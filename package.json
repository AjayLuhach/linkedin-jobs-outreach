{
  "name": "feed-email-extractor",
  "version": "2.0.0",
  "description": "CLI tool to extract hiring posts from LinkedIn feed, score against your resume, and draft personalized cold emails using AI",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "feed-email-extractor": "./src/cli.js"
  },
  "scripts": {
    "parse": "node src/cli.js parse",
    "parse:file": "node src/cli.js parse --file",
    "generate": "node src/cli.js generate",
    "emails": "node src/cli.js emails",
    "emails:redraft": "node src/cli.js emails --redraft",
    "send": "node src/cli.js send",
    "send:emails": "node src/scripts/send-emails.js",
    "send:verify": "node src/scripts/send-emails.js --verify",
    "send:list": "node src/scripts/send-emails.js --list",
    "dashboard": "node src/scripts/dashboard-server.js",
    "mailer": "node src/scripts/mailer-daemon.js",
    "mailer:stop": "node src/scripts/mailer-stop.js",
    "reset": "node src/scripts/reset-rejected.js"
  },
  "keywords": [
    "linkedin",
    "email",
    "hiring",
    "ai",
    "cli",
    "job-search"
  ],
  "author": "ajayluhach",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.990.0",
    "@google/generative-ai": "^0.21.0",
    "cheerio": "^1.2.0",
    "clipboardy": "^4.0.0",
    "dotenv": "^17.2.3",
    "nodemailer": "^6.9.0",
    "openai": "^6.29.0"
  }
}
